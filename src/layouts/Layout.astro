---
import "../styles/global.css";
const { title, description = 'Kanade的小窝', hideChrome = false } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="author" content="Kanade" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
  </head>

  <body>
    {!hideChrome && <header id="navbar" class="navbar">
      <div class="navbar-shell">
        <a href="/" class="brand" aria-label="返回首页">
          <span class="brand-mark">K</span>
          <span class="brand-text">Kanade</span>
        </a>

        <button
          id="menuToggle"
          class="menu-toggle"
          type="button"
          aria-label="切换导航菜单"
          aria-expanded="false"
        >
          <span></span>
          <span></span>
          <span></span>
        </button>

        <nav id="siteNav" class="site-nav" aria-label="主导航">
          <ul>
            <li><a href="/study/" data-nav="study">Notes</a></li>
            <li><a href="/blog/" data-nav="blog">Blog</a></li>
            <li><a href="/projects/" data-nav="projects">Projects</a></li>
            <li><a href="/about/" data-nav="about">About</a></li>
            <li><a href="/admin/" data-nav="admin">CMS</a></li>
          </ul>
        </nav>

        <div class="navbar-actions">
          <button id="themeToggle" class="icon-btn" type="button" aria-label="切换主题">🌙</button>
          <span class="avatar" aria-hidden="true">K</span>
        </div>
      </div>
      <div id="progressBar" class="progress-bar" aria-hidden="true"></div>
    </header>}

    <main>
      <slot />
    </main>

    {!hideChrome && <footer>
      <hr />
      <p>&copy; 2026 Kanade.</p>
      <p><a href="/changelog/">Recent Updates</a></p>
    </footer>}

    <script is:inline>
      const navbar = document.getElementById('navbar');
      const siteNav = document.getElementById('siteNav');
      const menuToggle = document.getElementById('menuToggle');
      const themeToggle = document.getElementById('themeToggle');
      const progressBar = document.getElementById('progressBar');
      const navLinks = Array.from(document.querySelectorAll('.site-nav a[data-nav]'));

      const applyTheme = (theme) => {
        document.documentElement.setAttribute('data-theme', theme);
        if (themeToggle) {
          themeToggle.textContent = theme === 'dark' ? '☀️' : '🌙';
        }
      };

      const getPreferredTheme = () => {
        const storedTheme = localStorage.getItem('theme');
        if (storedTheme) return storedTheme;
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };

      const setActiveLink = () => {
        const currentPath = window.location.pathname.replace(/\/+$/, '') || '/';

        navLinks.forEach((link) => {
          const targetPath = new URL(link.href, window.location.origin).pathname.replace(/\/+$/, '') || '/';
          link.classList.toggle('active', currentPath === targetPath);
        });
      };

      const updateNavbarState = () => {
        const scrolled = window.scrollY > 16;
        if (!navbar || !progressBar) return;
        navbar.classList.toggle('scrolled', scrolled);

        const scrollTop = window.scrollY;
        const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
        const progress = maxScroll > 0 ? (scrollTop / maxScroll) * 100 : 0;
        progressBar.style.width = `${Math.min(progress, 100)}%`;
      };

      const closeMobileMenu = () => {
        if (window.innerWidth <= 768) {
          siteNav.classList.remove('open');
          menuToggle?.setAttribute('aria-expanded', 'false');
        }
      };

      const toggleMobileMenu = () => {
        const isOpen = siteNav.classList.toggle('open');
        menuToggle?.setAttribute('aria-expanded', String(isOpen));
      };

      applyTheme(getPreferredTheme());
      setActiveLink();
      updateNavbarState();
      requestAnimationFrame(() => navbar.classList.add('ready'));

      window.addEventListener('scroll', updateNavbarState, { passive: true });
      window.addEventListener('resize', () => {
        if (window.innerWidth > 768) {
          closeMobileMenu();
        }
      });

      themeToggle?.addEventListener('click', () => {
        const nextTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        applyTheme(nextTheme);
        localStorage.setItem('theme', nextTheme);
      });

      menuToggle?.addEventListener('click', toggleMobileMenu);

      document.addEventListener('click', (event) => {
        if (window.innerWidth <= 768 && siteNav.classList.contains('open') && !navbar.contains(event.target)) {
          closeMobileMenu();
        }
      });

      document.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLImageElement)) return;
        if (!target.closest('.detail-content, .media-section')) return;

        const imageUrl = target.currentSrc || target.src;
        if (imageUrl) {
          window.open(imageUrl, '_blank', 'noopener,noreferrer');
        }
      });
    </script>
  </body>
</html>
