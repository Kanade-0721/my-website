---
import "../styles/global.css";

const { title, description = 'Kanade的小窝', hideChrome = false } = Astro.props;
---

<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="author" content="Kanade" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <script is:inline>
      window.MathJax = {
        tex: {
          inlineMath: [['$', '$'], ['\\(', '\\)']],
          displayMath: [['$$', '$$'], ['\\[', '\\]']],
          processEscapes: true,
        },
        options: {
          skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'pre', 'code'],
        },
      };
    </script>
    <script defer src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-chtml.js"></script>

    <title>{title}</title>
  </head>

  <body>
    {!hideChrome && (
      <header id="navbar" class="navbar">
        <div class="navbar-shell">
          <a href="/" class="brand" aria-label="返回首页">
            <span class="brand-mark">K</span>
            <span class="brand-text">Kanade</span>
          </a>

          <button
            id="menuToggle"
            class="menu-toggle"
            type="button"
            aria-label="切换导航菜单"
            aria-expanded="false"
          >
            <span></span>
            <span></span>
            <span></span>
          </button>

          <nav id="siteNav" class="site-nav" aria-label="主导航">
            <ul>
              <li><a href="/study/" data-nav="study">笔记</a></li>
              <li><a href="/blog/" data-nav="blog">博客</a></li>
              <li><a href="/projects/" data-nav="projects">项目</a></li>
              <li><a href="/about/" data-nav="about">关于</a></li>
              <li><a href="/admin/" data-nav="admin">CMS</a></li>
            </ul>
          </nav>

          <div class="navbar-actions">
            <button id="themeToggle" class="icon-btn" type="button" aria-label="切换主题">☾</button>
            <span class="avatar" aria-hidden="true">K</span>
          </div>
        </div>
        <div id="progressBar" class="progress-bar" aria-hidden="true"></div>
      </header>
    )}

    <main>
      <slot />
    </main>

    <div id="imageLightbox" class="image-lightbox" aria-hidden="true">
      <button class="image-lightbox__close" type="button" aria-label="关闭大图">×</button>
      <button class="image-lightbox__nav image-lightbox__nav--prev" type="button" aria-label="上一张">‹</button>
      <img id="imageLightboxImage" class="image-lightbox__image" alt="" />
      <button class="image-lightbox__nav image-lightbox__nav--next" type="button" aria-label="下一张">›</button>
    </div>

    {!hideChrome && (
      <footer>
        <hr />
        <p>&copy; 2026 Kanade.</p>
        <p><a href="/changelog/">Recent Updates</a></p>
      </footer>
    )}

    <script is:inline>
      const navbar = document.getElementById('navbar');
      const siteNav = document.getElementById('siteNav');
      const menuToggle = document.getElementById('menuToggle');
      const themeToggle = document.getElementById('themeToggle');
      const progressBar = document.getElementById('progressBar');
      const navLinks = Array.from(document.querySelectorAll('.site-nav a[data-nav]'));

      const applyTheme = (theme) => {
        document.documentElement.setAttribute('data-theme', theme);
        if (themeToggle) {
          themeToggle.textContent = theme === 'dark' ? '☀' : '☾';
        }
      };

      const getPreferredTheme = () => {
        const storedTheme = localStorage.getItem('theme');
        if (storedTheme) return storedTheme;
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };

      const setActiveLink = () => {
        const currentPath = window.location.pathname.replace(/\/+$/, '') || '/';

        navLinks.forEach((link) => {
          const targetPath = new URL(link.href, window.location.origin).pathname.replace(/\/+$/, '') || '/';
          link.classList.toggle('active', currentPath === targetPath);
        });
      };

      const updateNavbarState = () => {
        const scrolled = window.scrollY > 16;
        if (!navbar || !progressBar) return;
        navbar.classList.toggle('scrolled', scrolled);

        const scrollTop = window.scrollY;
        const maxScroll = document.documentElement.scrollHeight - window.innerHeight;
        const progress = maxScroll > 0 ? (scrollTop / maxScroll) * 100 : 0;
        progressBar.style.width = `${Math.min(progress, 100)}%`;
      };

      const closeMobileMenu = () => {
        if (window.innerWidth <= 768 && siteNav) {
          siteNav.classList.remove('open');
          menuToggle?.setAttribute('aria-expanded', 'false');
        }
      };

      const toggleMobileMenu = () => {
        if (!siteNav) return;
        const isOpen = siteNav.classList.toggle('open');
        menuToggle?.setAttribute('aria-expanded', String(isOpen));
      };

      applyTheme(getPreferredTheme());
      setActiveLink();
      updateNavbarState();
      if (navbar) {
        requestAnimationFrame(() => navbar.classList.add('ready'));
      }

      window.addEventListener('scroll', updateNavbarState, { passive: true });
      window.addEventListener('resize', () => {
        if (window.innerWidth > 768) {
          closeMobileMenu();
        }
      });

      themeToggle?.addEventListener('click', () => {
        const nextTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
        applyTheme(nextTheme);
        localStorage.setItem('theme', nextTheme);
      });

      menuToggle?.addEventListener('click', toggleMobileMenu);

      document.addEventListener('click', (event) => {
        if (
          window.innerWidth <= 768 &&
          siteNav?.classList.contains('open') &&
          navbar &&
          !navbar.contains(event.target)
        ) {
          closeMobileMenu();
        }
      });

      let lightboxImages = [];
      let lightboxIndex = -1;

      const getPageLightboxImages = () =>
        Array.from(document.querySelectorAll('.detail-panel img, .detail-content img, .media-section img, .media-grid img'))
          .filter((image) => image instanceof HTMLImageElement && (image.currentSrc || image.src));

      const updateLightboxImage = () => {
        const lightbox = document.getElementById('imageLightbox');
        const lightboxImage = document.getElementById('imageLightboxImage');
        if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) return;

        const currentImage = lightboxImages[lightboxIndex];
        if (!(currentImage instanceof HTMLImageElement)) return;

        lightboxImage.src = currentImage.currentSrc || currentImage.src;
        lightboxImage.alt = currentImage.alt || '图片大图';
        lightbox.classList.toggle('has-multiple', lightboxImages.length > 1);
      };

      const openLightbox = (image) => {
        const lightbox = document.getElementById('imageLightbox');
        if (!(lightbox instanceof HTMLElement)) return;

        lightboxImages = getPageLightboxImages();
        lightboxIndex = Math.max(0, lightboxImages.indexOf(image));
        updateLightboxImage();
        lightbox.classList.add('open');
        lightbox.setAttribute('aria-hidden', 'false');
        document.body.classList.add('lightbox-open');
      };

      const showLightboxImage = (direction) => {
        if (lightboxImages.length <= 1) return;
        lightboxIndex = (lightboxIndex + direction + lightboxImages.length) % lightboxImages.length;
        updateLightboxImage();
      };

      document.addEventListener('click', (event) => {
        const target = event.target;
        const image = target instanceof Element ? target.closest('img') : null;
        if (!(image instanceof HTMLImageElement)) return;
        if (!image.closest('.detail-panel, .detail-content, .media-section, .media-grid')) return;

        event.preventDefault();
        openLightbox(image);
      });

      const closeLightbox = () => {
        const lightbox = document.getElementById('imageLightbox');
        const lightboxImage = document.getElementById('imageLightboxImage');
        if (!(lightbox instanceof HTMLElement) || !(lightboxImage instanceof HTMLImageElement)) return;

        lightbox.classList.remove('open');
        lightbox.classList.remove('has-multiple');
        lightbox.setAttribute('aria-hidden', 'true');
        lightboxImage.removeAttribute('src');
        lightboxImages = [];
        lightboxIndex = -1;
        document.body.classList.remove('lightbox-open');
      };

      document.getElementById('imageLightbox')?.addEventListener('click', (event) => {
        const target = event.target;
        if (target instanceof HTMLElement && target.closest('.image-lightbox__nav--prev')) {
          event.stopPropagation();
          showLightboxImage(-1);
          return;
        }
        if (target instanceof HTMLElement && target.closest('.image-lightbox__nav--next')) {
          event.stopPropagation();
          showLightboxImage(1);
          return;
        }
        if (target instanceof HTMLElement && (target.id === 'imageLightbox' || target.closest('.image-lightbox__close'))) {
          closeLightbox();
        }
      });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          closeLightbox();
        }
        if (event.key === 'ArrowLeft') {
          showLightboxImage(-1);
        }
        if (event.key === 'ArrowRight') {
          showLightboxImage(1);
        }
      });
    </script>
  </body>
</html>
