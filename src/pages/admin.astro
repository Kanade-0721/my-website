---
import Layout from '../layouts/Layout.astro';

const title = 'CMS 编辑器';
const description = '通过 Git-based CMS 管理博客、笔记和项目内容';
---

<Layout title={title} description={description}>
  <section class="admin-workspace">
    <header class="panel-header">
      <p class="panel-eyebrow">内容管理</p>
      <h2>Git-based CMS</h2>
      <p class="panel-copy">内容会保存为仓库里的 Markdown 文件，并在重新部署后出现在站点中。</p>
    </header>
    <div id="nc-root"></div>
  </section>
</Layout>

<script is:inline src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>

<style is:global>
  main:has(.admin-workspace) {
    max-width: none;
    width: 100%;
    margin-bottom: 24px;
    padding: 88px 16px 0;
  }

  .admin-workspace {
    width: 100%;
    min-height: calc(100vh - 128px);
    margin: 0 auto;
    padding: 0;
    background: transparent;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }

  .admin-workspace .panel-header {
    display: none;
  }

  .admin-workspace #nc-root {
    min-height: calc(100vh - 96px);
  }

  .admin-workspace #nc-root > div,
  .admin-workspace #nc-root main,
  .admin-workspace #nc-root section {
    max-width: none !important;
  }

  .admin-workspace #nc-root main {
    width: 100% !important;
  }

  .admin-workspace #nc-root [class*="AppMainContainer"],
  .admin-workspace #nc-root [class*="CollectionMain"],
  .admin-workspace #nc-root [class*="EditorContainer"],
  .admin-workspace #nc-root [class*="EditorControl"],
  .admin-workspace #nc-root [class*="Editor"] {
    max-width: none !important;
  }

  .admin-workspace #nc-root textarea,
  .admin-workspace #nc-root [contenteditable="true"] {
    min-height: 52vh !important;
  }

  @media (max-width: 768px) {
    main:has(.admin-workspace) {
      padding: 84px 8px 0;
    }

    .admin-workspace {
      min-height: calc(100vh - 100px);
      padding: 12px;
      border-radius: 14px;
    }
  }
</style>
