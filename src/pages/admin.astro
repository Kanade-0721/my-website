---
import Layout from '../layouts/Layout.astro';

const title = 'CMS 编辑器';
const description = '通过 Git-based CMS 管理博客、笔记和项目内容';
---

<Layout title={title} description={description} hideChrome={true}>
  <section class="admin-workspace">
    <a class="admin-home-link" href="/" aria-label="返回主站">返回主站</a>
    <header class="panel-header">
      <p class="panel-eyebrow">内容管理</p>
      <h2>Git-based CMS</h2>
      <p class="panel-copy">内容会保存为仓库里的 Markdown 文件，并在重新部署后出现在站点中。</p>
    </header>
    <div id="nc-root"></div>
  </section>
</Layout>

<script is:inline src="https://unpkg.com/decap-cms@^3.0.0/dist/decap-cms.js"></script>

<style is:global>
  main:has(.admin-workspace) {
    max-width: none;
    width: 100%;
    margin-bottom: 24px;
    padding: 16px;
    overflow-x: hidden;
  }

  .admin-workspace {
    position: relative;
    width: min(1680px, 100%);
    min-height: calc(100vh - 150px);
    margin: 0 auto;
    padding: 20px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 20px;
    box-shadow: 0 20px 50px rgba(15, 23, 42, 0.12);
  }

  .admin-workspace .panel-header {
    margin-bottom: 12px;
  }

  .admin-workspace #nc-root {
    min-height: calc(100vh - 252px);
    overflow-x: auto;
  }

  .admin-home-link {
    position: fixed;
    right: 18px;
    bottom: 18px;
    z-index: 9999;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 36px;
    padding: 8px 12px;
    border-radius: 999px;
    background: rgba(17, 24, 39, 0.88);
    color: #fff;
    font-size: 0.88rem;
    font-weight: 600;
    text-decoration: none;
    box-shadow: 0 10px 24px rgba(15, 23, 42, 0.22);
  }

  .admin-home-link:hover {
    background: rgba(17, 24, 39, 1);
  }

  @media (max-width: 768px) {
    main:has(.admin-workspace) {
      margin-bottom: 0;
      padding: 0;
    }

    .admin-workspace {
      width: 100%;
      min-height: 100vh;
      padding: 0;
      background: var(--bg);
      border: 0;
      border-radius: 0;
      box-shadow: none;
    }

    .admin-workspace .panel-header {
      display: none;
    }

    .admin-workspace #nc-root {
      min-width: 0;
      min-height: 100vh;
      padding-bottom: 72px;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    .admin-home-link {
      right: 12px;
      bottom: 12px;
      min-height: 34px;
      padding: 7px 10px;
      font-size: 0.8rem;
      opacity: 0.88;
    }

    .admin-home-link:focus,
    .admin-home-link:hover {
      opacity: 1;
    }
  }

  @media (max-width: 480px) {
    .admin-home-link {
      right: 8px;
      bottom: 8px;
      max-width: calc(100vw - 16px);
    }
  }
</style>
