---
import Layout from '../../layouts/Layout.astro';
import { formatEntryDate, getEntriesInSection, getPublishedSections } from '../../lib/content';

export async function getStaticPaths() {
  const sections = await getPublishedSections('projectSections');

  return sections.map((section) => ({
    params: { section: section.id },
    props: { section },
  }));
}

const { section } = Astro.props;
const items = await getEntriesInSection('projects', section.id);
const latestDate = items[0]?.data.date ?? section.data.date;
const technologies = section.data.technologies ?? [];
const projectStatus = section.data.status ?? '进行中';
---

<Layout title={`${section.data.title} | 项目`} description={section.data.description}>
  <section class="glass-panel project-dossier">
    <a class="back-link" href="/projects/">← 返回项目分区</a>

    <header class="project-dossier__hero">
      <p class="panel-eyebrow">Technical Dossier</p>
      <div class="project-dossier__title">
        <div>
          <h2>{section.data.title}</h2>
          <p>{section.data.description}</p>
        </div>
        <span class={`status-pill status-pill--${projectStatus}`}>{projectStatus}</span>
      </div>
    </header>

    <div class="dossier-grid" aria-label="项目技术档案">
      <section class="dossier-card dossier-card--intro">
        <h3>项目简介</h3>
        <p>{section.data.description}</p>
      </section>

      <section class="dossier-card">
        <h3>使用技术</h3>
        {technologies.length > 0 ? (
          <div class="tech-stack">
            {technologies.map((technology) => <span>{technology}</span>)}
          </div>
        ) : (
          <p class="dossier-muted">暂未填写技术栈</p>
        )}
      </section>

      <section class="dossier-card dossier-card--stats">
        <h3>项目概况</h3>
        <dl class="dossier-stats">
          <div>
            <dt>最近更新时间</dt>
            <dd>{formatEntryDate(latestDate)}</dd>
          </div>
          <div>
            <dt>帖子数量</dt>
            <dd>{items.length}</dd>
          </div>
          <div>
            <dt>项目状态</dt>
            <dd>{projectStatus}</dd>
          </div>
        </dl>
      </section>
    </div>

    <section class="project-updates" aria-labelledby="project-updates-title">
      <header class="panel-header">
        <p class="panel-eyebrow">Project Updates</p>
        <h2 id="project-updates-title">技术记录</h2>
        <p class="panel-copy">这个项目中的技术问题、实现过程和阶段性记录都会整理在这里。</p>
      </header>

      <div class="panel-list" role="list">
        {items.length === 0 && (
          <div class="empty-state">
            <p>这个项目还没有更新帖。</p>
          </div>
        )}

        {items.map((item) => (
          <a class="panel-item" href={`/projects/${section.id}/${item.id}`} role="listitem">
            <div class="item-main">
              <h3>{item.data.title}</h3>
              <p>{item.data.description}</p>
            </div>
            <div class="item-meta">{formatEntryDate(item.data.date)}</div>
          </a>
        ))}
      </div>
    </section>
  </section>
</Layout>

<style>
  .project-dossier {
    width: min(980px, 100%);
  }

  .project-dossier__hero {
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.16);
  }

  .project-dossier__title {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: flex-start;
  }

  .project-dossier__title h2 {
    margin-bottom: 8px;
    font-size: clamp(1.9rem, 4vw, 3rem);
    line-height: 1.12;
  }

  .project-dossier__title p,
  .dossier-muted,
  .dossier-card p {
    color: var(--muted);
  }

  .status-pill {
    flex-shrink: 0;
    padding: 7px 12px;
    border-radius: 999px;
    background: rgba(96, 165, 250, 0.16);
    color: #2563eb;
    font-size: 0.85rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .status-pill--完成 {
    background: rgba(34, 197, 94, 0.16);
    color: #16a34a;
  }

  .status-pill--暂停 {
    background: rgba(245, 158, 11, 0.16);
    color: #d97706;
  }

  .dossier-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.95fr;
    gap: 14px;
    margin-bottom: 30px;
  }

  .dossier-card {
    padding: 18px;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.14);
    border-radius: 18px;
  }

  .dossier-card--intro {
    grid-row: span 2;
  }

  .dossier-card h3 {
    margin-bottom: 10px;
    font-size: 1rem;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tech-stack span {
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(96, 165, 250, 0.14);
    color: var(--text);
    font-size: 0.88rem;
    font-weight: 600;
  }

  .dossier-stats {
    display: grid;
    gap: 12px;
  }

  .dossier-stats div {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
  }

  .dossier-stats div:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .dossier-stats dt {
    color: var(--muted);
  }

  .dossier-stats dd {
    font-weight: 700;
    text-align: right;
  }

  .project-updates {
    margin-top: 4px;
  }

  @media (max-width: 760px) {
    .project-dossier__title,
    .dossier-stats div {
      flex-direction: column;
      gap: 8px;
    }

    .dossier-grid {
      grid-template-columns: 1fr;
    }

    .dossier-card--intro {
      grid-row: auto;
    }

    .dossier-stats dd {
      text-align: left;
    }
  }
</style>
