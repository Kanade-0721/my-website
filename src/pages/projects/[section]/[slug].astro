---
import Layout from '../../../layouts/Layout.astro';
import { render } from 'astro:content';
import { formatEntryDate, getPublishedEntries, getPublishedSections } from '../../../lib/content';

export async function getStaticPaths() {
  const projects = await getPublishedEntries('projects');
  const sections = await getPublishedSections('projectSections');

  return projects.map((project) => ({
    params: { section: project.data.section, slug: project.id },
    props: {
      project,
      section: sections.find((item) => item.id === project.data.section),
    },
  }));
}

const { project, section } = Astro.props;
const { Content } = await render(project);
const media = project.data.media;
const sectionHref = section ? `/projects/${section.id}` : '/projects/';
const sectionTitle = section?.data.title ?? '项目';
---

<Layout title={project.data.title} description={project.data.description}>
  <section class="glass-panel detail-panel">
    <a class="back-link" href={sectionHref}>← 返回{sectionTitle}</a>
    <header class="detail-header">
      <p class="panel-eyebrow">Project Update</p>
      <h1>{project.data.title}</h1>
      <p class="detail-meta">{formatEntryDate(project.data.date)} · {sectionTitle} · {project.data.tags.join(' · ')}</p>
    </header>
    {project.data.cover && <img class="media-image" src={project.data.cover} alt={project.data.title} loading="lazy" />}
    <div class="detail-content">
      <Content />
    </div>
    {(media.images.length > 0 || media.videos.length > 0 || media.audios.length > 0) && (
      <section class="media-section">
        <h3>附加媒体</h3>
        {media.images.length > 0 && (
          <div class="media-grid">
            {media.images.map((src) => (
              <img class="media-image" src={src} alt={project.data.title} loading="lazy" />
            ))}
          </div>
        )}
        {media.videos.length > 0 && (
          <div class="media-list">
            {media.videos.map((src) => (
              <video class="media-card" controls src={src} />
            ))}
          </div>
        )}
        {media.audios.length > 0 && (
          <div class="media-list">
            {media.audios.map((src) => (
              <audio class="media-card" controls src={src} />
            ))}
          </div>
        )}
      </section>
    )}
  </section>
</Layout>
