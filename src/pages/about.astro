---
import Layout from '../layouts/Layout.astro';
import AboutCard from '../components/AboutCard.astro';
import ContributionCalendar from '../components/ContributionCalendar.astro';
import ProfileSection from '../components/ProfileSection.astro';
import ProjectList from '../components/ProjectList.astro';
import { formatEntryDate, getEntriesInSection, getPublishedEntries, getPublishedSections } from '../lib/content';

const title = 'Kanade 的小窝 | 关于我';
const description = '关于 Kanade 的简要介绍';

const toDateKey = (date) => {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
};

async function getRecentSections(sectionCollection, entryCollection, basePath) {
  const sections = await getPublishedSections(sectionCollection);
  const sectionsWithLatest = await Promise.all(
    sections.map(async (section) => {
      const entries = await getEntriesInSection(entryCollection, section.id);
      const latestEntry = entries[0];
      const latestDate = latestEntry?.data.date ?? section.data.date;

      return {
        name: section.data.title,
        description: latestEntry ? latestEntry.data.title : '暂无更新',
        status: formatEntryDate(latestDate),
        href: `/${basePath}/${section.id}`,
        latestDate,
      };
    }),
  );

  return sectionsWithLatest
    .sort((a, b) => b.latestDate.getTime() - a.latestDate.getTime())
    .slice(0, 3);
}

const recentProjectSections = await getRecentSections('projectSections', 'projects', 'projects');
const recentNoteSections = await getRecentSections('studySections', 'study', 'study');

const allPosts = [
  ...(await getPublishedEntries('blog')),
  ...(await getPublishedEntries('study')),
  ...(await getPublishedEntries('projects')),
];
const contributionCounts = allPosts.reduce((counts, post) => {
  const key = toDateKey(post.data.date);
  counts.set(key, (counts.get(key) ?? 0) + 1);
  return counts;
}, new Map());
const contributions = Array.from(contributionCounts, ([date, count]) => ({ date, count }));
const luoguPosts = (await getPublishedEntries('blog')).filter((post) => post.body?.includes('LUOGU_DAILY_ITEM'));
const luoguCounts = luoguPosts.reduce((counts, post) => {
  const key = toDateKey(post.data.date);
  const solvedCount = post.body.match(/<!-- LUOGU_DAILY_ITEM /g)?.length ?? 0;
  counts.set(key, (counts.get(key) ?? 0) + solvedCount);
  return counts;
}, new Map());
const luoguContributions = Array.from(luoguCounts, ([date, count]) => ({ date, count }));
const luoguTotal = luoguContributions.reduce((total, item) => total + item.count, 0);
const calendarDatasets = [
  {
    id: 'updates',
    label: '更新日历',
    totalLabel: '总 post 数',
    countUnit: '篇更新',
    tone: 'green',
    contributions,
    totalPosts: allPosts.length,
  },
  {
    id: 'luogu',
    label: '刷题日历',
    totalLabel: '总题数',
    countUnit: '道题',
    tone: 'red',
    contributions: luoguContributions,
    totalPosts: luoguTotal,
  },
];
---

<Layout title={title} description={description}>
  <section class="about-shell">
    <div class="about-glass">
      <div class="about-grid">
        <ProfileSection
          name="Kanade"
          title="北京大学工学院本科生"
          location="北京海淀"
          email="kanade0721@126.com"
          role="游戏，动漫，coding"
          statusLabel="爱好"
          avatarSrc="/uploads/profile-avatar.jpg"
          avatarAlt="Kanade 的头像"
        >
          <Fragment slot="tagline">
            今天总是和昨天不一样，所以很珍贵
          </Fragment>
          <Fragment slot="links">
            <a class="text-link" href="/blog/">Blog</a>
            <a class="text-link" href="https://github.com/Kanade-0721" target="_blank" rel="noreferrer">GitHub</a>
            <a class="text-link" href="mailto:kanade0721@126.com">邮箱</a>
          </Fragment>
          <Fragment slot="extra">
            <ContributionCalendar datasets={calendarDatasets} />
          </Fragment>
        </ProfileSection>

        <div class="about-side">
          <AboutCard title="近期项目" subtitle="最近更新的三个项目分区">
            <ProjectList projects={recentProjectSections} emptyText="项目分区创建后，会自动显示最近更新的三个分区。" />
          </AboutCard>

          <AboutCard title="正在学习" subtitle="最近更新的三个笔记分区">
            <ProjectList projects={recentNoteSections} emptyText="笔记分区创建后，会自动显示最近更新的三个分区。" />
          </AboutCard>
        </div>
      </div>
    </div>
  </section>
</Layout>
