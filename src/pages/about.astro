---
import Layout from '../layouts/Layout.astro';
import AboutCard from '../components/AboutCard.astro';
import ProfileSection from '../components/ProfileSection.astro';
import ProjectList from '../components/ProjectList.astro';
import SkillTags from '../components/SkillTags.astro';
import { formatEntryDate, getPublishedEntries } from '../lib/content';

const title = 'Kanade 的小窗 | 关于我';
const description = '关于 Kanade 的简要介绍';

const latestProjects = (await getPublishedEntries('projects')).slice(0, 3);
const projects = latestProjects.map((project) => ({
  name: project.data.title,
  description: project.data.description,
  status: formatEntryDate(project.data.date),
  href: `/projects/${project.id}`,
}));

const skills = ['Astro', 'React', 'TypeScript', 'CSS', 'Figma', 'Git'];
---

<Layout title={title} description={description}>
  <section class="about-shell">
    <div class="about-glass">
      <div class="about-grid">
        <ProfileSection
          name="Kanade"
          title="Creative Developer"
          location="Shanghai, China"
          email="hello@kanade.design"
          role="Open to thoughtful side projects"
          avatar="K"
        >
          <Fragment slot="tagline">
            I build calm, modern experiences that feel clear, tactile, and alive.
          </Fragment>
          <Fragment slot="links">
            <a class="text-link" href="/blog/">Blog</a>
            <a class="text-link" href="https://github.com" target="_blank" rel="noreferrer">GitHub</a>
          </Fragment>
        </ProfileSection>

        <div class="about-side">
          <AboutCard title="Current Projects" subtitle="最近更新的项目">
            <ProjectList projects={projects} />
          </AboutCard>

          <AboutCard title="Learning" subtitle="持续扩展的技能栈">
            <SkillTags items={skills} />
          </AboutCard>
        </div>
      </div>
    </div>
  </section>
</Layout>
