---

<Layout title={title} description={description}>
  <section class="changelog-hero">
    <p class="panel-eyebrow">Changelog</p>
    <h1>更新日志</h1>
    <p>记录网站从基础框架、静态展示页，到可维护内容系统的每一步调整。</p>
  </section>

  <section class="timeline" aria-label="网站更新记录">
    {updates.map((update) => (
      <article class="timeline-entry">
        <time datetime={update.date}>{update.date}</time>
        <div class="timeline-dot" aria-hidden="true"></div>
        <div class="timeline-body">
          <h2>{update.title}</h2>
          <ul>
            {update.items.map((item) => <li>{item}</li>)}
          </ul>
        </div>
      </article>
    ))}
  </section>
</Layout>

<style>
  .changelog-hero {
    width: min(860px, 100%);
    margin: 0 auto 34px;
  }

  .changelog-hero h1 {
    margin-bottom: 10px;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.1;
  }

  .changelog-hero p:not(.panel-eyebrow) {
    max-width: 680px;
    color: var(--muted);
  }

  .timeline {
    position: relative;
    display: grid;
    gap: 0;
    width: min(900px, 100%);
    margin: 0 auto;
  }

  .timeline::before {
    content: '';
    position: absolute;
    top: 6px;
    bottom: 6px;
    left: 134px;
    width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(96, 165, 250, 0.7), rgba(148, 163, 184, 0.2));
  }

  .timeline-entry {
    position: relative;
    display: grid;
    grid-template-columns: 108px 28px minmax(0, 1fr);
    gap: 18px;
    padding: 0 0 34px;
  }

  .timeline-entry time {
    padding-top: 3px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 700;
    text-align: right;
  }

  .timeline-dot {
    position: relative;
    z-index: 1;
    width: 11px;
    height: 11px;
    margin: 7px auto 0;
    border: 2px solid #60a5fa;
    border-radius: 50%;
    background: var(--bg);
    box-shadow: 0 0 0 6px rgba(96, 165, 250, 0.12);
  }

  .timeline-body {
    padding: 0 0 28px;
    border-bottom: 1px solid rgba(148, 163, 184, 0.2);
  }

  .timeline-entry:last-child,
  .timeline-entry:last-child .timeline-body {
    padding-bottom: 0;
    border-bottom: 0;
  }

  .timeline-body h2 {
    margin-bottom: 12px;
    font-size: 1.22rem;
  }

  .timeline-body ul {
    display: grid;
    gap: 8px;
    padding-left: 1.1rem;
    color: var(--text);
  }

  .timeline-body li::marker {
    color: #60a5fa;
  }

  @media (max-width: 640px) {
    .timeline::before {
      left: 5px;
    }

    .timeline-entry {
      grid-template-columns: 18px minmax(0, 1fr);
      gap: 12px;
      padding-bottom: 30px;
    }

    .timeline-entry time {
      grid-column: 2;
      grid-row: 1;
      padding-top: 0;
      text-align: left;
    }

    .timeline-dot {
      grid-column: 1;
      grid-row: 1 / span 2;
      margin-top: 8px;
    }

    .timeline-body {
      grid-column: 2;
      grid-row: 2;
    }
  }
</style>
