---
import Layout from '../../layouts/Layout.astro';
import CodeProjectViewer from '../../components/CodeProjectViewer.astro';
import { render } from 'astro:content';
import { formatEntryDate, getPublishedEntries } from '../../lib/content';

export async function getStaticPaths() {
  const posts = await getPublishedEntries('blog');

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const media = post.data.media;
const tagText = post.data.tags.length > 0 ? ` · ${post.data.tags.join(' · ')}` : '';
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="reading-panel detail-panel">
    <a class="back-link" href="/blog/">← 返回博客</a>
    <header class="detail-header">
      <p class="panel-eyebrow">Blog Detail</p>
      <h1>{post.data.title}</h1>
      <p class="detail-meta">{formatEntryDate(post.data.date)}{tagText}</p>
    </header>
    {post.data.cover && <img class="detail-cover" src={post.data.cover} alt={post.data.title} loading="lazy" />}
    <div class="detail-content">
      <Content />
    </div>
    {post.data.codeProject?.enabled && post.data.codeProject.archive && (
      <CodeProjectViewer
        archive={post.data.codeProject.archive}
        entry={post.data.codeProject.entry}
        title={post.data.codeProject.title ?? post.data.title}
      />
    )}
    {(media.images.length > 0 || media.videos.length > 0 || media.audios.length > 0) && (
      <section class="media-section">
        <h3>Attached media</h3>
        {media.images.length > 0 && (
          <div class="media-grid">
            {media.images.map((src) => (
              <img class="media-image" src={src} alt={post.data.title} loading="lazy" />
            ))}
          </div>
        )}
        {media.videos.length > 0 && (
          <div class="media-list">
            {media.videos.map((src) => (
              <video class="media-card" controls src={src} />
            ))}
          </div>
        )}
        {media.audios.length > 0 && (
          <div class="media-list">
            {media.audios.map((src) => (
              <audio class="media-card" controls src={src} />
            ))}
          </div>
        )}
      </section>
    )}
  </article>
</Layout>
