---
type Contribution = {
  date: string;
  count: number;
};

type CalendarDataset = {
  id: string;
  label: string;
  totalLabel: string;
  countUnit: string;
  tone?: 'green' | 'red';
  contributions: Contribution[];
  totalPosts: number;
};

const fallbackDatasets: CalendarDataset[] = [
  {
    id: 'updates',
    label: '更新日历',
    totalLabel: '总 post 数',
    countUnit: '篇更新',
    tone: 'green',
    contributions: Astro.props.contributions ?? [],
    totalPosts: Astro.props.totalPosts ?? 0,
  },
];

const datasets: CalendarDataset[] = Astro.props.datasets?.length ? Astro.props.datasets : fallbackDatasets;

const today = new Date();
today.setHours(0, 0, 0, 0);

const year = today.getFullYear();
const start = new Date(year, 0, 1);
const end = new Date(year, 11, 31);
const totalDays = Math.floor((end.getTime() - start.getTime()) / 86400000) + 1;

const dayLabels = [
  { label: '一', row: 2 },
  { label: '三', row: 4 },
  { label: '五', row: 6 },
];
const monthLabels = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];

const toDateKey = (date: Date) => {
  const year = date.getFullYear();
  const month = String(date.getMonth() + 1).padStart(2, '0');
  const day = String(date.getDate()).padStart(2, '0');
  return `${year}-${month}-${day}`;
};

const buildDays = (dataset: CalendarDataset) => {
  const contributionMap = new Map<string, number>(dataset.contributions.map((item) => [item.date, item.count]));

  return Array.from({ length: totalDays }, (_, index) => {
    const date = new Date(start);
    date.setDate(start.getDate() + index);
    const key = toDateKey(date);
    const count = contributionMap.get(key) ?? 0;
    const week = Math.floor((index + start.getDay()) / 7) + 1;
    const day = date.getDay() + 1;

    return {
      key,
      count,
      week,
      day,
      label: `${key}: ${count} ${dataset.countUnit}`,
      level: Math.min(count, 4),
    };
  });
};

const calendars = datasets.map((dataset) => {
  const days = buildDays(dataset);
  const monthMarkers = days
    .filter((day) => new Date(day.key).getDate() === 1)
    .map((day) => ({
      label: monthLabels[new Date(day.key).getMonth()],
      week: day.week,
    }));

  return {
    ...dataset,
    days,
    monthMarkers,
    tone: dataset.tone ?? 'green',
  };
});
---

<section class="contribution-calendar" aria-label="活跃日历" data-calendar-root>
  <div class="contribution-calendar__header">
    <button class="contribution-calendar__toggle" type="button" aria-label="切换日历" data-calendar-toggle>
      <span aria-hidden="true">›</span>
    </button>
    <span data-calendar-title>{calendars[0]?.label}</span>
  </div>

  <div class="contribution-calendar__flip" data-calendar-flip>
    <div class="contribution-calendar__flip-inner">
      {calendars.map((calendar, index) => (
        <div
          class="contribution-calendar__panel"
          data-calendar-panel
          data-label={calendar.label}
          data-active={index === 0 ? 'true' : 'false'}
          data-tone={calendar.tone}
          data-face={index === 0 ? 'front' : 'back'}
        >
          <div class="contribution-calendar__months" aria-hidden="true">
            {calendar.monthMarkers.map((month) => (
              <span style={`grid-column: ${month.week};`}>{month.label}</span>
            ))}
          </div>

          <div class="contribution-calendar__body">
            <div class="contribution-calendar__days" aria-hidden="true">
              {dayLabels.map((day) => <span style={`grid-row: ${day.row};`}>{day.label}</span>)}
            </div>

            <div class="contribution-calendar__grid">
              {calendar.days.map((day) => (
                <span
                  class="contribution-calendar__cell"
                  data-level={day.level}
                  style={`grid-column: ${day.week}; grid-row: ${day.day};`}
                  title={day.label}
                  aria-label={day.label}
                />
              ))}
            </div>
          </div>

          <div class="contribution-calendar__footer">
            <span>{calendar.totalLabel}：{calendar.totalPosts}</span>
            <div class="contribution-calendar__legend" aria-hidden="true">
              <span>少</span>
              <i data-level="0"></i>
              <i data-level="1"></i>
              <i data-level="2"></i>
              <i data-level="3"></i>
              <i data-level="4"></i>
              <span>多</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-calendar-root]').forEach((root) => {
    const button = root.querySelector('[data-calendar-toggle]');
    const title = root.querySelector('[data-calendar-title]');
    const panels = Array.from(root.querySelectorAll('[data-calendar-panel]'));
    let activeIndex = 0;

    button?.addEventListener('click', () => {
      activeIndex = (activeIndex + 1) % panels.length;
      root.setAttribute('data-flipped', String(activeIndex === 1));

      panels.forEach((panel, index) => {
        panel.setAttribute('data-active', String(index === activeIndex));
      });

      if (title) {
        title.textContent = panels[activeIndex]?.getAttribute('data-label') ?? '';
      }
    });
  });
</script>
