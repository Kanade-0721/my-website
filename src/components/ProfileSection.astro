---
const {
  name = 'Kanade',
  title = '北京大学工学院本科生',
  location = '北京海淀',
  email = 'kanade0721@126.com',
  role = '游戏，动漫，coding',
  avatar = 'K',
  avatarSrc,
  avatarAlt = '',
  statusLabel = '爱好',
} = Astro.props;
---

<aside class="profile-section">
  <div class="profile-avatar" aria-hidden={avatarSrc ? undefined : 'true'}>
    {avatarSrc ? <img src={avatarSrc} alt={avatarAlt || name} loading="lazy" /> : avatar}
  </div>
  <div class="profile-content">
    <h2>{name}</h2>
    <p class="profile-title">{title}</p>
    <p class="profile-tagline">
      <slot name="tagline" />
    </p>

    <ul class="profile-meta">
      <li><span>所在地</span><strong>{location}</strong></li>
      <li><span>联系邮箱</span><strong>{email}</strong></li>
      <li><span>{statusLabel}</span><strong>{role}</strong></li>
    </ul>

    <div class="profile-links">
      <slot name="links" />
    </div>
  </div>
</aside>
